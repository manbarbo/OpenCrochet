{
  "name": "@opencrochet/api",
  "version": "1.0.0",
  "description": "OpenCrochet API - Image processing and filet crochet pattern generation",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\"",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sharp": "^0.33.0",
    "multer": "^1.4.5-lts.1",
    "joi": "^17.13.0",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.0",
    "winston": "^3.14.0",
    "dotenv": "^16.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "@opencrochet/shared-types": "workspace:*",
    "@opencrochet/image-processing": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
