    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@opencrochet/shared-types": "workspace:*",
    "@opencrochet/ui-components": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^7.17.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
