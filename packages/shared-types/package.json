{
  "name": "@opencrochet/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for OpenCrochet",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "jest": "^30.4.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "ts-jest": "^29.4.11",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4"
  }
}
