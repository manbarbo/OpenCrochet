{
  "name": "@opencrochet/ui-components",
  "version": "1.0.0",
  "description": "Shared MUI components for OpenCrochet",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "rm -rf dist node_modules"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@mui/material": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "jest": "^30.4.2",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.4.11",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4"
  }
}
